{
    "version": 2,
    "builds": [
        {
            "src": "client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist",
                "buildCommand": "npm run build"
            }
        },
        {
            "src": "server/api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "client/$1",
            "check": true
        },
        {
            "src": "/(.*)",
            "status": 200,
            "dest": "client/index.html"
        }
    ]
}